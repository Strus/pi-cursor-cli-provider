{
    "name": "@akepka/pi-cursor-cli-provider",
    "version": "0.10.1",
    "description": "Cursor CLI provider extension for Pi",
    "keywords": [
        "pi",
        "pi-package",
        "pi-coding-agent",
        "extension",
        "provider",
        "cursor"
    ],
    "author": "Adrian Kepka",
    "type": "module",
    "license": "MIT",
    "files": [
        "src",
        "types",
        "README.md",
        "LICENSE",
        "header.jpeg"
    ],
    "pi": {
        "extensions": [
            "./src/index.ts"
        ]
